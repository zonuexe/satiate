{
    "name": "zonuexe/satiate",
    "license": "AGPL-3.0-or-later",
    "require": {
        "php": ">=8.5",
        "symfony/console": "^8.1"
    },
    "require-dev": {
        "bamarni/composer-bin-plugin": "*",
        "phpstan/phpstan": "^2.2"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "bamarni/composer-bin-plugin": true
        }
    },
    "extra": {
        "bamarni-bin": {
            "bin-links": false,
            "forward-command": true
        }
    }
}
