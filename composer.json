{
    "name": "zonuexe/satiate",
    "license": "AGPL-3.0-or-later",
    "bin": ["bin/satiate"],
    "require": {
        "php": ">=8.5",
        "composer/composer": "^2.10",
        "nikic/php-parser": "^5.7",
        "symfony/console": "^8.1"
    },
    "require-dev": {
        "bamarni/composer-bin-plugin": "*",
        "phan/phan": "^6.0",
        "php-http/discovery": "^1.19",
        "spatie/phpunit-snapshot-assertions": "^5.4"
    },
    "autoload": {
        "psr-4": {
            "Satiate\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Satiate\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "bamarni/composer-bin-plugin": true
        }
    },
    "scripts": {
        "phpstan": "bin/phpstan",
        "ecs": "bin/ecs",
        "phpunit": "bin/phpunit"
    },
    "extra": {
        "bamarni-bin": {
            "bin-links": false,
            "forward-command": true,
            "target-directory": ".vendor-bin"
        }
    }
}
