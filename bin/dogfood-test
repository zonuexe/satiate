#!/bin/bash
set -euo pipefail

# Satiate end-to-end dogfooding test
#
# Proves satiate produces a *working* static Composer repository:
#   1. Build a mirror from the locally installed packages (path repositories).
#   2. Assert every required package — including ones the resolver used to drop — is present.
#   3. Serve it over HTTP and install packages straight from the mirror with Packagist
#      DISABLED, so a broken mirror (a dropped package, a bad dist checksum) fails the test
#      instead of silently falling back to packagist.org.
#
# Versioning note: a `path` repository over an installed vendor tree has no release tags, so
# Composer derives a dev version from the enclosing checkout — "dev-master" on a named branch, but
# "dev-<commit-sha>" on a detached HEAD (e.g. GitHub Actions PR builds). Either way it is a dev
# version with no comparable semver, so the mirror-only installs below all use "@dev" (which matches
# any dev version) rather than caret constraints, which would only resolve via a branch-alias that
# happens to match the guessed branch name. Packages with many caret-constrained dependencies
# (symfony/console, phpunit/phpunit) cannot install from such a mirror in isolation — their
# transitive deps are dev versions too — so they are only asserted to be present, not installed.

PROJECT_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
SATIATE_BIN="$PROJECT_ROOT/bin/satiate"
OUTDIR=$(mktemp -d /tmp/satiate-www-XXXX)
TMPDIR=$(mktemp -d /tmp/satiate-test-XXXX)
trap 'rm -rf "$OUTDIR" "$TMPDIR"; kill $(lsof -ti:8888) 2>/dev/null || true' EXIT

echo "=== 1. Building repository from locally installed packages ==="

# Include all package sources: root vendor + each vendor-bin
cat > "$TMPDIR/satis.json" << SATIS
{
    "name": "Dogfood Repository",
    "homepage": "http://localhost:8888",
    "repositories": [
        {"type": "path", "url": "$PROJECT_ROOT/vendor/*/*"},
        {"type": "path", "url": "$PROJECT_ROOT/.vendor-bin/phpstan/vendor/*/*"},
        {"type": "path", "url": "$PROJECT_ROOT/.vendor-bin/easycs/vendor/*/*"},
        {"type": "path", "url": "$PROJECT_ROOT/.vendor-bin/phpunit/vendor/*/*"}
    ],
    "require": {
        "symfony/console": "^8.1",
        "nikic/php-parser": "^5.7",
        "phpunit/phpunit": "^13.2",
        "phpstan/phpstan": "^2.2",
        "psr/log": "^3.0"
    },
    "require-all": false,
    "require-dependencies": true,
    "max-versions-per-package": 3,
    "archive": {
        "directory": "dist",
        "format": "zip",
        "prefix-url": "http://localhost:8888"
    }
}
SATIS

"$SATIATE_BIN" build -c "$TMPDIR/satis.json" --output-dir "$OUTDIR" --no-audit 2>&1

echo ""
echo "=== 2. Packages available in the mirror ==="
python3 -c "
import json
d = json.load(open('$OUTDIR/packages.json'))
pkgs = d.get('packages', {})
if isinstance(pkgs, dict):
    for name, versions in sorted(pkgs.items()):
        print(f'  ✅ {name}: {sorted(versions.keys(), key=str)}')
    print(f'  TOTAL: {len(pkgs)} packages')
else:
    print(f'  ⚠️ packages is {type(pkgs).__name__} ({len(pkgs)} entries)')
"

echo ""
echo "=== 3. Asserting required packages were not dropped from the mirror ==="
# Regression guard: path-repo dev versions (dev-master) used to be filtered out by their caret
# constraint, leaving the mirror nearly empty. Every required package must survive into the mirror.
python3 -c "
import json, sys
d = json.load(open('$OUTDIR/packages.json'))
have = set(d.get('packages', {}).keys())
required = ['symfony/console', 'nikic/php-parser', 'phpunit/phpunit', 'phpstan/phpstan', 'psr/log']
missing = [p for p in required if p not in have]
if missing:
    print('  ❌ MISSING from mirror:', missing)
    sys.exit(1)
print('  ✅ all required packages present:', required)
"

echo ""
echo "=== 4. Starting HTTP server on localhost:8888 ==="
php -S localhost:8888 -t "$OUTDIR" &>/tmp/satiate-server.log &
sleep 1
curl -s http://localhost:8888/packages.json | python3 -c "import json,sys; d=json.load(sys.stdin); print('Server OK —', len(d.get('available-packages',[])), 'packages available')"

# install_from_mirror <package> <constraint> <slug>
# Installs a single package straight from the satiate mirror with Packagist DISABLED. A dropped
# package or a dist checksum that Composer rejects makes `composer install` fail, which (under
# `set -e` + `pipefail`) aborts the whole script — so this genuinely exercises the mirror.
install_from_mirror () {
    pkg="$1"; constraint="$2"; slug="$3"; dir="$TMPDIR/install-$slug"
    mkdir -p "$dir"
    cat > "$dir/composer.json" << EOF
{
    "name": "satiate/install-$slug",
    "version": "1.0.0",
    "repositories": {
        "satiate": {"type": "composer", "url": "http://localhost:8888"},
        "packagist.org": false
    },
    "require": {"$pkg": "$constraint"},
    "minimum-stability": "dev",
    "config": {"secure-http": false}
}
EOF
    ( cd "$dir" && composer install --no-interaction 2>&1 | tail -4 )
    if [ ! -d "$dir/vendor/$pkg" ]; then
        echo "  ❌ $pkg NOT installed from mirror"
        exit 1
    fi
    echo "  ✅ $pkg installed from the mirror (packagist disabled)"
}

echo ""
echo "=== 5. Installing nikic/php-parser from the mirror (@dev) ==="
install_from_mirror "nikic/php-parser" "@dev" "php-parser"

echo ""
echo "=== 6. Installing psr/log from the mirror (@dev) ==="
install_from_mirror "psr/log" "@dev" "psr-log"

echo ""
echo "=== 7. Installing phpstan/phpstan from the mirror (leaf package, @dev) ==="
install_from_mirror "phpstan/phpstan" "@dev" "phpstan"

echo ""
echo "=== 8. Audit the repository (listing critical findings, summarising the rest) ==="
# A mirror of real libraries trips many benign warnings (dynamic includes, exec, ...), so list
# only critical findings individually and let the summary report the per-severity counts.
"$SATIATE_BIN" audit --path "$OUTDIR" --min-severity critical 2>&1 | tail -8

echo ""
echo "=== Dogfooding test complete ==="
echo "SUCCESS"
