#!/bin/bash
set -euo pipefail

# Satiate dogfooding integration test
# Verifies constraint propagation with a real package resolution

PROJECT_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
SATIATE_BIN="$PROJECT_ROOT/bin/satiate"
WORKDIR=$(mktemp -d /tmp/satiate-dogfood-XXXX)
trap 'rm -rf "$WORKDIR"' EXIT

echo "=== Satiate Dogfooding Test ==="

# Build a repository using our own vendor packages
cat > "$WORKDIR/satis.json" << SATIS
{
    "name": "Dogfood Test",
    "homepage": "http://localhost:8888",
    "repositories": [
        {"type": "path", "url": "$PROJECT_ROOT/vendor/psr/container"},
        {"type": "path", "url": "$PROJECT_ROOT/vendor/psr/log"},
        {"type": "path", "url": "$PROJECT_ROOT/vendor/nikic/php-parser"}
    ],
    "require": {
        "psr/container": "^2.0",
        "nikic/php-parser": "^5.7"
    },
    "require-all": false,
    "require-dependencies": true,
    "max-versions-per-package": 3
}
SATIS

echo "--- Building repository ---"
"$SATIATE_BIN" build -c "$WORKDIR/satis.json" --output-dir "$WORKDIR/output" --no-audit 2>&1

echo ""
echo "--- Analyzing output ---"
python3 - "$WORKDIR/output/packages.json" << 'PYEOF'
import json, sys

d = json.load(open(sys.argv[1]))
pkgs = d.get('packages', {})

if not isinstance(pkgs, dict):
    print(f"❌ FAIL: packages is {type(pkgs).__name__}, expected dict")
    sys.exit(1)

versions_count = sum(len(v) for v in pkgs.values() if isinstance(v, dict))
print(f"Total packages: {len(pkgs)}")
print(f"Total versions: {versions_count}")
print()

# Check version counts
suspect = 0
for name, versions in sorted(pkgs.items()):
    vlist = sorted(versions.keys(), key=lambda x: str(x))
    if len(vlist) > 5:
        print(f"  ⚠️  {name}: {len(vlist)} versions ({vlist[0]} ~ {vlist[-1]})")
        suspect += 1
    else:
        print(f"  ✅ {name}: {len(vlist)} version{'s' if len(vlist) != 1 else ''}")

print()
if suspect > 0:
    print(f"❌ FAIL: {suspect} packages have excessive versions (>5)")
    sys.exit(1)

# Verify key packages are present
required = {'psr/container', 'nikic/php-parser'}
missing = required - set(pkgs.keys())
if missing:
    print(f"❌ FAIL: Missing required packages: {missing}")
    sys.exit(1)

print("✅ PASS: All checks passed")
sys.exit(0)
PYEOF

echo ""
echo "=== Dogfooding test complete ==="
